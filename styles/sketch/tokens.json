{
  "name": "Sketch / Hand-Drawn",
  "version": "1.0.0",
  "created": "2025-12-03",
  "description": "Authentic imperfection and human touch - wobbly borders, handwritten fonts, paper textures, and playful rotation",
  
  "colors": {
    "background": {
      "hex": "#fdfbf7",
      "name": "Warm Paper",
      "usage": "Page background"
    },
    "foreground": {
      "hex": "#2d2d2d",
      "name": "Soft Pencil Black",
      "usage": "Text, borders (never use pure black)"
    },
    "muted": {
      "hex": "#e5e0d8",
      "name": "Old Paper / Erased",
      "usage": "Secondary backgrounds, placeholders, disabled states"
    },
    "accent": {
      "hex": "#ff4d4d",
      "name": "Red Correction Marker",
      "usage": "Primary actions, emphasis, alerts"
    },
    "accentSecondary": {
      "hex": "#2d5da1",
      "name": "Blue Ballpoint Pen",
      "usage": "Links, focus states, secondary actions"
    },
    "card": {
      "hex": "#ffffff",
      "name": "White",
      "usage": "Card backgrounds"
    },
    "postit": {
      "hex": "#fff9c4",
      "name": "Post-it Yellow",
      "usage": "Feature highlights, sticky notes, callouts"
    }
  },

  "typography": {
    "fontFamily": {
      "heading": "'Kalam', cursive",
      "body": "'Patrick Hand', cursive",
      "googleImport": "https://fonts.googleapis.com/css2?family=Kalam:wght@400;700&family=Patrick+Hand&display=swap"
    },
    "fontWeight": {
      "normal": 400,
      "bold": 700
    },
    "fontSize": {
      "hero": {
        "mobile": "3rem",
        "desktop": "3.75rem"
      },
      "sectionHeading": {
        "mobile": "2.25rem",
        "desktop": "3rem"
      },
      "cardHeading": {
        "mobile": "1.5rem",
        "desktop": "1.875rem"
      },
      "body": {
        "mobile": "1.125rem",
        "desktop": "1.25rem"
      },
      "small": "1rem"
    },
    "lineHeight": {
      "heading": 1.2,
      "body": 1.6
    }
  },

  "wobblyRadius": {
    "standard": {
      "value": "255px 15px 225px 15px / 15px 225px 15px 255px",
      "usage": "Buttons, small cards, badges"
    },
    "medium": {
      "value": "15px 225px 15px 255px / 255px 15px 225px 15px",
      "usage": "Cards, containers, modals"
    },
    "blob": {
      "value": "60% 40% 70% 30% / 30% 60% 40% 70%",
      "usage": "Stats, badges, organic shapes"
    },
    "subtle": {
      "value": "20px 25px 20px 25px / 25px 20px 25px 20px",
      "usage": "Inputs, form elements"
    }
  },

  "borders": {
    "width": {
      "standard": "2px",
      "emphasis": "3px"
    },
    "color": "#2d2d2d",
    "style": {
      "primary": "solid",
      "secondary": "dashed"
    }
  },

  "shadows": {
    "standard": {
      "value": "4px 4px 0px 0px #2d2d2d",
      "usage": "Buttons, interactive elements"
    },
    "emphasized": {
      "value": "8px 8px 0px 0px #2d2d2d",
      "usage": "Highlighted cards, modals"
    },
    "subtle": {
      "value": "3px 3px 0px 0px rgba(45, 45, 45, 0.1)",
      "usage": "Cards at rest"
    },
    "hover": {
      "value": "2px 2px 0px 0px #2d2d2d",
      "usage": "Button hover state (reduced offset)"
    }
  },

  "effects": {
    "paperTexture": {
      "backgroundImage": "radial-gradient(#e5e0d8 1px, transparent 1px)",
      "backgroundSize": "24px 24px"
    },
    "tape": {
      "width": "60px",
      "height": "20px",
      "background": "rgba(200, 200, 200, 0.6)"
    },
    "thumbtack": {
      "size": "16px",
      "color": "#ff4d4d"
    }
  },

  "rotation": {
    "subtle": {
      "positive": "1deg",
      "negative": "-1deg"
    },
    "standard": {
      "positive": "2deg",
      "negative": "-2deg"
    }
  },

  "animation": {
    "duration": {
      "fast": "100ms",
      "normal": "200ms",
      "bounce": "3s"
    },
    "easing": {
      "default": "ease-out"
    }
  },

  "layout": {
    "maxWidth": "1024px",
    "containerPadding": "24px"
  },

  "components": {
    "button": {
      "primary": {
        "background": "#ffffff",
        "backgroundHover": "#ff4d4d",
        "color": "#2d2d2d",
        "colorHover": "#ffffff",
        "border": "3px solid #2d2d2d",
        "shadow": "4px 4px 0px 0px #2d2d2d",
        "shadowHover": "2px 2px 0px 0px #2d2d2d"
      }
    },
    "card": {
      "background": "#ffffff",
      "border": "2px solid #2d2d2d",
      "shadow": "3px 3px 0px 0px rgba(45, 45, 45, 0.1)"
    },
    "input": {
      "background": "#ffffff",
      "border": "2px solid #2d2d2d",
      "borderFocus": "2px solid #2d5da1"
    }
  },

  "icons": {
    "library": "lucide-react",
    "strokeWidth": {
      "standard": 2.5,
      "emphasis": 3
    }
  }
}
