{
  "name": "Academia / Classical",
  "version": "1.0.0",
  "created": "2025-12-03",
  "description": "Scholarly gravitas meets timeless elegance. Channels centuries-old university libraries, Victorian study halls, and Renaissance manuscripts with rich material references and traditional typographic excellence.",

  "colors": {
    "background": "#1C1714",
    "backgroundAlt": "#251E19",
    "foreground": "#E8DFD4",
    "muted": "#3D332B",
    "mutedForeground": "#9C8B7A",
    "accent": "#C9A962",
    "accentSecondary": "#8B2635",
    "accentForeground": "#1C1714",
    "border": "#4A3F35"
  },

  "colorNames": {
    "background": "Deep Mahogany",
    "backgroundAlt": "Aged Oak",
    "foreground": "Antique Parchment",
    "muted": "Worn Leather",
    "mutedForeground": "Faded Ink",
    "accent": "Polished Brass",
    "accentSecondary": "Library Crimson",
    "border": "Wood Grain"
  },

  "typography": {
    "fontFamily": {
      "heading": "Cormorant Garamond",
      "body": "Crimson Pro",
      "display": "Cinzel",
      "googleImport": "https://fonts.googleapis.com/css2?family=Cinzel:wght@400;500;600;700&family=Cormorant+Garamond:ital,wght@0,400;0,500;0,600;0,700;1,400;1,500&family=Crimson+Pro:ital,wght@0,400;0,500;0,600;1,400;1,500&display=swap"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "fontSize": {
      "display": {
        "mobile": "3rem",
        "tablet": "3.75rem",
        "desktop": "4.5rem"
      },
      "sectionHeading": {
        "mobile": "2.25rem",
        "tablet": "2.5rem",
        "desktop": "3rem"
      },
      "subsectionHeading": {
        "mobile": "1.5rem",
        "tablet": "1.875rem",
        "desktop": "1.875rem"
      },
      "body": {
        "mobile": "1rem",
        "desktop": "1.125rem"
      },
      "label": {
        "small": "0.625rem",
        "default": "0.75rem"
      },
      "dropCap": "4.5rem"
    },
    "lineHeight": {
      "display": 1.1,
      "heading": 1.2,
      "body": 1.625,
      "dropCap": 0.8
    },
    "letterSpacing": {
      "tight": "-0.025em",
      "normal": "0em",
      "wide": "0.15em",
      "wider": "0.2em",
      "widest": "0.3em"
    }
  },

  "spacing": {
    "base": 8,
    "scale": [0, 4, 8, 12, 16, 24, 32, 48, 64, 96, 128],
    "section": {
      "mobile": { "paddingY": 64, "paddingX": 16 },
      "tablet": { "paddingY": 80, "paddingX": 24 },
      "desktop": { "paddingY": 96, "paddingX": 32 }
    },
    "card": {
      "padding": 32,
      "paddingLarge": 48
    },
    "gap": {
      "micro": 8,
      "element": 16,
      "section": 32
    }
  },

  "borders": {
    "width": {
      "default": "1px",
      "decorative": "2px"
    },
    "color": {
      "default": "#4A3F35",
      "interactive": "#C9A962"
    },
    "radius": {
      "default": "4px",
      "archTop": "40% 40% 0 0 / 20% 20% 0 0",
      "full": "9999px"
    }
  },

  "shadows": {
    "none": "none",
    "cardHover": "0 8px 24px rgba(0,0,0,0.3)",
    "engraved": "inset 0 1px 0 rgba(255,255,255,0.2), inset 0 -1px 0 rgba(0,0,0,0.2), 0 2px 8px rgba(0,0,0,0.3)",
    "waxSeal": "inset 0 2px 4px rgba(255,255,255,0.2), inset 0 -2px 4px rgba(0,0,0,0.3), 0 4px 8px rgba(0,0,0,0.4)",
    "brassGlow": "0 4px 12px rgba(201,169,98,0.3)"
  },

  "effects": {
    "brassGradient": "linear-gradient(180deg, #D4B872 0%, #C9A962 50%, #B8953F 100%)",
    "engravedText": "1px 1px 1px rgba(0,0,0,0.4), -1px -1px 1px rgba(255,255,255,0.1)",
    "sepiaFilter": "sepia(0.6) contrast(0.95) brightness(0.9)",
    "vignette": "radial-gradient(ellipse at center, transparent 0%, transparent 50%, rgba(28,23,20,0.4) 100%)",
    "ornateDivider": "linear-gradient(90deg, transparent 0%, #4A3F35 20%, #C9A962 50%, #4A3F35 80%, transparent 100%)"
  },

  "animation": {
    "duration": {
      "fast": "150ms",
      "base": "300ms",
      "slow": "500ms",
      "dramatic": "700ms"
    },
    "easing": {
      "default": "ease-out"
    },
    "transforms": {
      "cardHover": "none",
      "imageHover": "scale(1.05)",
      "buttonActive": "none"
    }
  },

  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },

  "layout": {
    "maxWidth": {
      "content": "1152px",
      "narrow": "896px",
      "full": "1280px"
    },
    "containerPadding": {
      "mobile": "1rem",
      "tablet": "1.5rem",
      "desktop": "2rem"
    }
  },

  "components": {
    "button": {
      "primary": {
        "background": "linear-gradient(180deg, #D4B872 0%, #C9A962 50%, #B8953F 100%)",
        "text": "#1C1714",
        "border": "none",
        "height": {
          "small": "40px",
          "default": "48px",
          "large": "56px"
        }
      },
      "secondary": {
        "background": "transparent",
        "text": "#C9A962",
        "border": "2px solid #C9A962",
        "hoverBackground": "#8B2635",
        "hoverBorder": "#8B2635",
        "hoverText": "#E8DFD4"
      },
      "ghost": {
        "background": "transparent",
        "text": "#C9A962",
        "border": "none",
        "hoverDecoration": "underline"
      }
    },
    "card": {
      "background": "#251E19",
      "border": "1px solid #4A3F35",
      "padding": "32px",
      "radius": "4px",
      "hover": {
        "border": "1px solid rgba(201,169,98,0.5)",
        "shadow": "0 8px 24px rgba(0,0,0,0.3)"
      }
    },
    "input": {
      "height": "48px",
      "background": "#251E19",
      "border": "1px solid #4A3F35",
      "focusBorder": "#C9A962",
      "text": "#E8DFD4",
      "placeholder": "#9C8B7A"
    }
  },

  "decorative": {
    "cornerFlourish": {
      "size": "40px",
      "sizeSmall": "24px",
      "color": "#C9A962",
      "borderWidth": "2px"
    },
    "waxSeal": {
      "size": "48px",
      "background": "radial-gradient(circle, #A62D3D 0%, #8B2635 60%, #6B1D28 100%)",
      "iconColor": "#E8DFD4"
    },
    "dropCap": {
      "font": "Cinzel",
      "size": "4.5rem",
      "color": "#C9A962",
      "shadow": "2px 2px 4px rgba(0,0,0,0.3)"
    },
    "romanNumerals": ["I", "II", "III", "IV", "V", "VI", "VII", "VIII", "IX", "X"],
    "ornateGlyphs": ["✶", "❧", "✤", "❦", "⚜"]
  },

  "texture": {
    "paperNoise": {
      "type": "svg",
      "filter": "feTurbulence",
      "baseFrequency": 0.9,
      "numOctaves": 4,
      "opacity": 0.03,
      "blendMode": "overlay",
      "position": "fixed"
    },
    "vignette": {
      "type": "radialGradient",
      "opacity": 1,
      "position": "fixed"
    }
  },

  "accessibility": {
    "contrast": {
      "foregroundOnBackground": "8.5:1",
      "mutedOnBackground": "4.5:1",
      "brassOnBackground": "7:1",
      "darkOnBrass": "8:1"
    },
    "focusRing": "2px solid #C9A962 with 2px offset",
    "minTouchTarget": "48px"
  }
}
