{
  "name": "Playful Geometric",
  "version": "1.0.0",
  "created": "2025-12-03",
  "description": "Optimistic, tactile, bouncy design with primitive shapes, hard shadows, and confetti-style decoration. Memphis Group inspired but modernized.",

  "colors": {
    "background": {
      "hex": "#FFFDF5",
      "name": "Warm Cream",
      "usage": "Page background (paper feel)"
    },
    "foreground": {
      "hex": "#1E293B",
      "name": "Slate 800",
      "usage": "Text, borders (softer than black)"
    },
    "muted": {
      "hex": "#F1F5F9",
      "name": "Slate 100",
      "usage": "Secondary backgrounds, cards"
    },
    "mutedForeground": {
      "hex": "#64748B",
      "name": "Slate 500",
      "usage": "Muted text, descriptions"
    },
    "accent": {
      "hex": "#8B5CF6",
      "name": "Vivid Violet",
      "usage": "Primary actions, brand color"
    },
    "accentForeground": {
      "hex": "#FFFFFF",
      "name": "White",
      "usage": "Text on accent backgrounds"
    },
    "secondary": {
      "hex": "#F472B6",
      "name": "Hot Pink",
      "usage": "Playful pop, decoration, alternating"
    },
    "tertiary": {
      "hex": "#FBBF24",
      "name": "Amber Yellow",
      "usage": "Optimism, hover states, highlights"
    },
    "quaternary": {
      "hex": "#34D399",
      "name": "Emerald Mint",
      "usage": "Freshness, success, decoration"
    },
    "border": {
      "hex": "#E2E8F0",
      "name": "Slate 200",
      "usage": "Default borders, soft shadows"
    },
    "input": {
      "hex": "#FFFFFF",
      "name": "White",
      "usage": "Input backgrounds"
    },
    "card": {
      "hex": "#FFFFFF",
      "name": "White",
      "usage": "Card backgrounds"
    },
    "ring": {
      "hex": "#8B5CF6",
      "name": "Violet",
      "usage": "Focus rings"
    }
  },

  "typography": {
    "fontFamily": {
      "heading": "'Outfit', system-ui, sans-serif",
      "body": "'Plus Jakarta Sans', system-ui, sans-serif",
      "googleImport": "https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&family=Plus+Jakarta+Sans:wght@400;500;600;700&display=swap"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "fontSize": {
      "hero": {
        "mobile": "3rem",
        "desktop": "3.75rem"
      },
      "sectionHeading": {
        "mobile": "1.875rem",
        "desktop": "2.25rem"
      },
      "cardHeading": {
        "mobile": "1.25rem",
        "desktop": "1.5rem"
      },
      "body": {
        "mobile": "1rem",
        "desktop": "1.125rem"
      },
      "small": "0.875rem",
      "label": "0.75rem"
    },
    "lineHeight": {
      "heading": 1.2,
      "body": 1.6
    },
    "letterSpacing": {
      "heading": "-0.02em",
      "body": "0",
      "label": "0.05em"
    }
  },

  "spacing": {
    "base": "4px",
    "scale": [0, 4, 8, 12, 16, 20, 24, 32, 40, 48, 64, 80, 96],
    "section": {
      "vertical": "96px",
      "verticalMobile": "64px"
    },
    "card": {
      "padding": {
        "mobile": "20px",
        "desktop": "24px"
      }
    },
    "gap": {
      "grid": "32px",
      "elements": "16px"
    }
  },

  "radius": {
    "sm": "8px",
    "md": "16px",
    "lg": "24px",
    "xl": "32px",
    "full": "9999px",
    "blob": {
      "speechBubble": "24px 24px 24px 0",
      "archTop": "9999px 9999px 0 0",
      "leaf": "0 24px 0 24px",
      "asymmetric": "60% 40% 30% 70% / 60% 30% 70% 40%"
    }
  },

  "borders": {
    "width": {
      "standard": "2px",
      "thick": "3px"
    },
    "color": {
      "default": "#E2E8F0",
      "dark": "#1E293B"
    },
    "style": "solid"
  },

  "shadows": {
    "pop": {
      "value": "4px 4px 0px 0px #1E293B",
      "usage": "Default interactive elements"
    },
    "popHover": {
      "value": "6px 6px 0px 0px #1E293B",
      "usage": "Hover lift effect"
    },
    "popActive": {
      "value": "2px 2px 0px 0px #1E293B",
      "usage": "Active/pressed state"
    },
    "soft": {
      "value": "8px 8px 0px 0px #E2E8F0",
      "usage": "Cards at rest"
    },
    "pink": {
      "value": "8px 8px 0px 0px #F472B6",
      "usage": "Featured cards, pink accent"
    },
    "violet": {
      "value": "4px 4px 0px 0px #8B5CF6",
      "usage": "Focus states, violet accent"
    },
    "yellow": {
      "value": "4px 4px 0px 0px #FBBF24",
      "usage": "Tertiary accent shadow"
    },
    "mint": {
      "value": "4px 4px 0px 0px #34D399",
      "usage": "Success, quaternary accent"
    },
    "none": {
      "value": "none",
      "usage": "No shadow (active press)"
    }
  },

  "effects": {
    "dotGrid": {
      "backgroundImage": "radial-gradient(#E2E8F0 2px, transparent 2px)",
      "backgroundSize": "20px 20px"
    },
    "diagonalStripes": {
      "backgroundImage": "repeating-linear-gradient(45deg, transparent, transparent 10px, #E2E8F0 10px, #E2E8F0 20px)"
    }
  },

  "animation": {
    "duration": {
      "fast": "150ms",
      "normal": "300ms",
      "slow": "500ms"
    },
    "easing": {
      "default": "ease-out",
      "bouncy": "cubic-bezier(0.34, 1.56, 0.64, 1)"
    },
    "keyframes": {
      "popIn": {
        "0%": { "transform": "scale(0)", "opacity": "0" },
        "70%": { "transform": "scale(1.1)" },
        "100%": { "transform": "scale(1)", "opacity": "1" }
      },
      "wiggle": {
        "0%, 100%": { "transform": "rotate(0deg)" },
        "25%": { "transform": "rotate(3deg)" },
        "75%": { "transform": "rotate(-3deg)" }
      },
      "bounce": {
        "0%, 100%": { "transform": "translateY(0)" },
        "50%": { "transform": "translateY(-10px)" }
      },
      "float": {
        "0%, 100%": { "transform": "translateY(0) rotate(0deg)" },
        "50%": { "transform": "translateY(-10px) rotate(5deg)" }
      }
    }
  },

  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },

  "layout": {
    "maxWidth": "1152px",
    "containerPadding": "24px"
  },

  "components": {
    "button": {
      "primary": {
        "background": "#8B5CF6",
        "color": "#FFFFFF",
        "border": "2px solid #1E293B",
        "borderRadius": "9999px",
        "shadow": "4px 4px 0px 0px #1E293B",
        "shadowHover": "6px 6px 0px 0px #1E293B",
        "shadowActive": "2px 2px 0px 0px #1E293B",
        "translateHover": "-2px",
        "translateActive": "2px"
      },
      "secondary": {
        "background": "transparent",
        "backgroundHover": "#FBBF24",
        "color": "#1E293B",
        "border": "2px solid #1E293B",
        "borderRadius": "9999px"
      },
      "minHeight": "48px",
      "paddingX": "24px",
      "paddingY": "12px"
    },
    "card": {
      "background": "#FFFFFF",
      "border": "2px solid #1E293B",
      "borderRadius": "24px",
      "shadow": "8px 8px 0px 0px #E2E8F0",
      "shadowFeatured": "8px 8px 0px 0px #F472B6",
      "hoverRotation": "-1deg",
      "hoverScale": "1.02",
      "padding": {
        "mobile": "20px",
        "desktop": "24px"
      }
    },
    "input": {
      "background": "#FFFFFF",
      "border": "2px solid #CBD5E1",
      "borderFocus": "2px solid #8B5CF6",
      "borderRadius": "16px",
      "shadowFocus": "4px 4px 0px 0px #8B5CF6",
      "padding": "12px 16px"
    },
    "badge": {
      "background": "#FBBF24",
      "color": "#1E293B",
      "border": "2px solid #1E293B",
      "borderRadius": "9999px",
      "padding": "4px 12px"
    }
  },

  "accessibility": {
    "focusRing": {
      "width": "2px",
      "color": "#8B5CF6",
      "offset": "2px"
    },
    "minTouchTarget": "48px",
    "contrastRatios": {
      "foregroundOnBackground": "12.5:1",
      "whiteOnViolet": "4.6:1",
      "foregroundOnYellow": "8.2:1"
    }
  },

  "decorativeElements": {
    "confettiColors": ["#8B5CF6", "#F472B6", "#FBBF24", "#34D399"],
    "shapes": {
      "circle": {
        "borderRadius": "50%"
      },
      "triangle": {
        "css": "border-left: 20px solid transparent; border-right: 20px solid transparent; border-bottom: 35px solid currentColor;"
      },
      "square": {
        "rotation": "45deg"
      },
      "pill": {
        "borderRadius": "9999px"
      }
    },
    "squiggle": {
      "strokeWidth": 3,
      "path": "M0 8 Q 25 0, 50 8 T 100 8"
    },
    "dashedConnector": {
      "stroke": "#E2E8F0",
      "strokeWidth": 2,
      "strokeDasharray": "8 8"
    }
  },

  "icons": {
    "library": "lucide-react",
    "strokeWidth": 2.5,
    "style": {
      "lineCap": "round",
      "lineJoin": "round"
    },
    "enclosure": {
      "shape": "circle",
      "size": "40px",
      "border": "2px solid #1E293B"
    }
  }
}
