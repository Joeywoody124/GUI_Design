{
  "name": "Hydrolight",
  "version": "1.0.0",
  "created": "2026-07-10",
  "description": "Sunlight through clear water - a light-mode water/stormwater engineering aesthetic. Depth gradients (cyan to navy), caustic shimmer, water-tinted shadows, wave dividers, monospace gauge readouts, and semantic hydro status colors. Built for water resources engineering tools.",
  "mode": "light",
  "keywords": ["clear", "luminous", "precise", "calm", "fluid", "trustworthy", "engineering-grade", "refractive", "water", "stormwater"],

  "colors": {
    "background": {
      "hex": "#F0F9FF",
      "name": "Surface Light (Sky 50)",
      "usage": "Page background - sunlit water surface"
    },
    "backgroundAlt": {
      "hex": "#E0F2FE",
      "name": "Shallows (Sky 100)",
      "usage": "Alternate sections, striped table rows"
    },
    "surface": {
      "hex": "#FFFFFF",
      "name": "White Cap",
      "usage": "Cards and raised elements"
    },
    "card": {
      "hex": "#FFFFFF",
      "name": "White Cap",
      "usage": "Card background (alias of surface for loader compatibility)"
    },
    "foreground": {
      "hex": "#082F49",
      "name": "Deep Channel (Sky 950)",
      "usage": "Primary text - highest contrast"
    },
    "primary": {
      "hex": "#0284C7",
      "name": "Open Water (Sky 600)",
      "usage": "Core brand color - buttons, active states, titles"
    },
    "primaryDeep": {
      "hex": "#075985",
      "name": "Thalweg (Sky 800)",
      "usage": "Gradient depth end, hover states, dark headers"
    },
    "accent": {
      "hex": "#0284C7",
      "name": "Open Water (Sky 600)",
      "usage": "Primary action color (alias of primary for loader compatibility)"
    },
    "accentSecondary": {
      "hex": "#06B6D4",
      "name": "Caustic Cyan (Cyan 500)",
      "usage": "Gradient surface end, glows, active/hover accents"
    },
    "secondary": {
      "hex": "#06B6D4",
      "name": "Caustic Cyan (Cyan 500)",
      "usage": "Secondary accent, gradient start"
    },
    "tertiary": {
      "hex": "#0D9488",
      "name": "Seagrass (Teal 600)",
      "usage": "Green infrastructure, pervious area accents"
    },
    "muted": {
      "hex": "#E0F2FE",
      "name": "Shallows (Sky 100)",
      "usage": "Muted backgrounds, disabled fills"
    },
    "mutedForeground": {
      "hex": "#475569",
      "name": "Silt (Slate 600)",
      "usage": "Supporting text, unit labels, hints"
    },
    "border": {
      "hex": "#BAE6FD",
      "name": "Ripple Line (Sky 200)",
      "usage": "Default borders, subtle separation"
    },
    "borderLight": {
      "hex": "#E0F2FE",
      "name": "Faint Ripple (Sky 100)",
      "usage": "Card borders"
    },
    "linkText": {
      "hex": "#0369A1",
      "name": "Navigable (Sky 700)",
      "usage": "Links and small primary-colored text (AA on white)"
    },
    "flood": {
      "hex": "#DC2626",
      "name": "Flood Stage (Red 600)",
      "usage": "Exceedance, errors, failed criteria (e.g., HW/D > 1.2)"
    },
    "floodBg": {
      "hex": "#FEF2F2",
      "name": "Flood Wash (Red 50)",
      "usage": "Exceedance badge/alert background"
    },
    "action": {
      "hex": "#D97706",
      "name": "Action Stage (Amber 600)",
      "usage": "Warnings, approaching capacity, freeboard deficits"
    },
    "actionBg": {
      "hex": "#FFFBEB",
      "name": "Action Wash (Amber 50)",
      "usage": "Warning badge/alert background"
    },
    "normal": {
      "hex": "#059669",
      "name": "Within Banks (Emerald 600)",
      "usage": "Success, passing criteria, within capacity"
    },
    "normalBg": {
      "hex": "#ECFDF5",
      "name": "Normal Wash (Emerald 50)",
      "usage": "Success badge/alert background"
    }
  },

  "gradients": {
    "depth": {
      "value": "linear-gradient(180deg, #06B6D4 0%, #0284C7 55%, #075985 100%)",
      "tailwind": "bg-[linear-gradient(180deg,#06B6D4_0%,#0284C7_55%,#075985_100%)]",
      "usage": "SIGNATURE - hero cards, headers, primary buttons; always vertical, light above dark"
    },
    "shallows": {
      "value": "linear-gradient(180deg, #E0F2FE 0%, #BAE6FD 100%)",
      "tailwind": "bg-gradient-to-b from-sky-100 to-sky-200",
      "usage": "Section backgrounds, icon badges"
    },
    "surfaceSheen": {
      "value": "linear-gradient(180deg, rgba(255,255,255,0.25) 0%, transparent 40%)",
      "usage": "Wet-glass highlight overlay on gradient cards"
    },
    "text": {
      "value": "linear-gradient(90deg, #0284C7, #06B6D4)",
      "tailwind": "bg-gradient-to-r from-sky-600 to-cyan-500 bg-clip-text text-transparent",
      "usage": "Gradient text for key headline words only"
    },
    "gaugeBar": {
      "value": "linear-gradient(90deg, #06B6D4, #0284C7)",
      "usage": "Progress/capacity bars in gauge readouts"
    }
  },

  "typography": {
    "fontFamily": {
      "primary": "'Manrope', 'Segoe UI', system-ui, sans-serif",
      "data": "'JetBrains Mono', Consolas, monospace",
      "googleImport": "https://fonts.googleapis.com/css2?family=Manrope:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500;700&display=swap"
    },
    "weights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "sizes": {
      "xs": { "size": "12px", "lineHeight": 1.4, "letterSpacing": "0.01em" },
      "sm": { "size": "14px", "lineHeight": 1.5, "letterSpacing": "0" },
      "base": { "size": "16px", "lineHeight": 1.6, "letterSpacing": "0" },
      "lg": { "size": "18px", "lineHeight": 1.5, "letterSpacing": "0" },
      "xl": { "size": "20px", "lineHeight": 1.35, "letterSpacing": "0" },
      "2xl": { "size": "24px", "lineHeight": 1.3, "letterSpacing": "-0.01em" },
      "3xl": { "size": "30px", "lineHeight": 1.2, "letterSpacing": "-0.01em" },
      "4xl": { "size": "36px", "lineHeight": 1.15, "letterSpacing": "-0.02em" },
      "5xl": { "size": "48px", "lineHeight": 1.1, "letterSpacing": "-0.02em" }
    },
    "elements": {
      "hero": { "size": "5xl", "weight": 800, "font": "primary" },
      "sectionHeading": { "size": "3xl", "weight": 700, "font": "primary" },
      "cardTitle": { "size": "lg", "weight": 600, "font": "primary" },
      "body": { "size": "base", "weight": 400, "font": "primary" },
      "label": { "size": "sm", "weight": 600, "font": "primary" },
      "gaugeValue": { "size": "3xl", "weight": 700, "font": "data", "note": "tabular numerals, right-aligned" },
      "dataTable": { "size": "sm", "weight": 400, "font": "data", "note": "right-align numerics" },
      "unitLabel": { "size": "xs", "weight": 500, "font": "primary", "color": "mutedForeground", "transform": "uppercase" }
    }
  },

  "spacing": {
    "containerMaxWidth": "1152px",
    "containerPadding": { "mobile": "16px", "tablet": "24px", "desktop": "32px" },
    "sectionPadding": { "mobile": "48px", "tablet": "64px", "desktop": "80px" },
    "cardPadding": "24px",
    "inputPadding": { "x": "16px", "y": "10px" },
    "buttonPadding": { "x": "24px", "y": "12px" },
    "gap": { "xs": "8px", "sm": "12px", "md": "16px", "lg": "24px", "xl": "32px" }
  },

  "borders": {
    "width": { "default": "1px", "focus": "2px", "alertAccent": "3px (left edge, state color)" },
    "radius": {
      "sm": "8px",
      "md": "10px",
      "lg": "12px",
      "xl": "14px",
      "2xl": "20px",
      "full": "9999px"
    },
    "radiusUsage": {
      "cards": "xl (14px)",
      "heroCards": "2xl (20px)",
      "inputs": "md (10px)",
      "buttons": "lg (12px) - rounded rectangle, NOT pill",
      "gaugeReadouts": "md (10px)",
      "badges": "full (pill) - status chips only"
    }
  },

  "shadows": {
    "surface": {
      "value": "0 1px 3px rgba(2, 132, 199, 0.08), 0 1px 2px rgba(2, 132, 199, 0.06)",
      "usage": "Resting cards - water-tinted, never gray"
    },
    "float": {
      "value": "0 8px 24px -4px rgba(2, 132, 199, 0.18), 0 4px 8px -2px rgba(2, 132, 199, 0.10)",
      "usage": "Hover elevation"
    },
    "deep": {
      "value": "0 16px 40px -8px rgba(7, 89, 133, 0.30)",
      "usage": "Modals, depth-gradient hero cards"
    },
    "button": {
      "value": "0 4px 14px rgba(2, 132, 199, 0.35)",
      "usage": "Primary CTAs"
    },
    "buttonHover": {
      "value": "0 6px 20px rgba(2, 132, 199, 0.45)",
      "usage": "Primary CTA hover"
    },
    "glow": {
      "value": "0 0 24px rgba(6, 182, 212, 0.45)",
      "usage": "Caustic glow accents, active gauge highlight"
    },
    "insetPool": {
      "value": "inset 0 2px 6px rgba(7, 89, 133, 0.12)",
      "usage": "Recessed input wells and panels"
    }
  },

  "effects": {
    "causticShimmer": {
      "description": "Slow overlapping radial white highlights animated over depth-gradient surfaces",
      "animation": "hydro-caustics 14s ease-in-out infinite alternate",
      "reducedMotion": "disable entirely"
    },
    "waveDivider": {
      "description": "SVG sine-wave section separator, two offset paths in Sky 100 and Sky 200 at 60% opacity",
      "height": { "desktop": "48px", "mobile": "32px" }
    },
    "rippleOrbs": {
      "description": "Large blurred cyan/sky gradient circles fixed behind content",
      "blur": "64px",
      "opacity": "0.20-0.25"
    },
    "surfaceLine": {
      "description": "2px white horizontal highlight along top edge of gradient cards (water surface)"
    }
  },

  "animation": {
    "philosophy": "Water moves; it never jitters. Slow, easing, continuous. No bounce or overshoot.",
    "duration": {
      "fast": "150ms",
      "default": "200ms",
      "slow": "500ms",
      "rise": "900ms",
      "caustics": "14000ms"
    },
    "easing": {
      "default": "ease-out",
      "surface": "ease-in-out",
      "rise": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "keyframes": {
      "hydroFloat": {
        "0%, 100%": { "transform": "translateY(0px)" },
        "50%": { "transform": "translateY(-8px)" }
      },
      "hydroRipple": {
        "from": { "boxShadow": "0 0 0 0 rgba(6, 182, 212, 0.35)" },
        "to": { "boxShadow": "0 0 0 10px rgba(6, 182, 212, 0)" }
      },
      "hydroRise": {
        "from": { "width": "0%" }
      }
    },
    "hoverEffects": {
      "cardLift": { "transform": "translateY(-4px)", "shadow": "float" },
      "buttonLift": { "transform": "translateY(-2px)", "shadow": "buttonHover" },
      "tableRow": { "background": "#E0F2FE" },
      "link": { "color": "#075985", "textDecoration": "underline" }
    }
  },

  "components": {
    "button": {
      "primary": {
        "background": "#0284C7",
        "backgroundGradient": "linear-gradient(180deg, #06B6D4 0%, #0284C7 55%, #075985 100%)",
        "text": "#FFFFFF",
        "fontWeight": 600,
        "padding": "12px 24px",
        "radius": "12px",
        "shadow": "button",
        "hoverTransform": "translateY(-2px)",
        "hoverShadow": "buttonHover"
      },
      "secondary": {
        "background": "#FFFFFF",
        "text": "#0369A1",
        "fontWeight": 600,
        "padding": "12px 24px",
        "radius": "12px",
        "border": "1px solid #BAE6FD",
        "hoverBackground": "#F0F9FF",
        "hoverBorder": "1px solid #7DD3FC"
      }
    },
    "card": {
      "background": "#FFFFFF",
      "radius": "14px",
      "border": "1px solid #E0F2FE",
      "shadow": "surface",
      "padding": "24px",
      "hoverTransform": "translateY(-4px)",
      "hoverShadow": "float"
    },
    "input": {
      "background": "#FFFFFF",
      "backgroundResting": "rgba(240, 249, 255, 0.6)",
      "text": "#082F49",
      "font": "data (JetBrains Mono / Consolas) for numeric fields",
      "placeholder": "#94A3B8",
      "border": "1px solid #BAE6FD",
      "radius": "10px",
      "padding": "10px 16px",
      "shadow": "insetPool (subtle)",
      "focusRing": "4px rgba(6, 182, 212, 0.25)",
      "focusBorder": "#0284C7",
      "focusBackground": "#FFFFFF"
    },
    "gaugeReadout": {
      "background": "#FFFFFF",
      "radius": "10px",
      "border": "1px solid #E0F2FE",
      "labelColor": "#475569",
      "labelTransform": "uppercase, 12px, semibold, wide tracking",
      "valueFont": "data",
      "valueSize": "30-36px",
      "valueColor": "#082F49",
      "unitColor": "#475569",
      "capacityBar": "6px track #E0F2FE, fill linear-gradient(90deg, #06B6D4, #0284C7)"
    },
    "statusBadge": {
      "shape": "pill",
      "padding": "4px 12px",
      "fontSize": "12px",
      "fontWeight": 600,
      "variants": {
        "flood": { "bg": "#FEF2F2", "text": "#B91C1C", "border": "#FECACA", "prefix": "▲" },
        "action": { "bg": "#FFFBEB", "text": "#B45309", "border": "#FDE68A", "prefix": "◆" },
        "normal": { "bg": "#ECFDF5", "text": "#047857", "border": "#A7F3D0", "prefix": "●" },
        "baseflow": { "bg": "#F0F9FF", "text": "#0369A1", "border": "#BAE6FD", "prefix": "~" }
      }
    },
    "alertCard": {
      "structure": "left border 3px in state color, 50-weight wash background, state 200 border",
      "radius": "14px",
      "padding": "16px"
    }
  },

  "accessibility": {
    "contrastRatios": {
      "textOnBackground": "15.9:1 (Sky 950 on Sky 50) - AAA",
      "textOnPrimary": "4.6:1 (White on Sky 600) - AA, use bold >= 15px",
      "linkOnWhite": "6.0:1 (Sky 700 on White) - AA",
      "mutedOnBackground": "7.4:1 (Slate 600 on Sky 50) - AAA"
    },
    "focusRing": {
      "width": "4px",
      "color": "rgba(6, 182, 212, 0.25)",
      "borderShift": "#0284C7",
      "style": "ring + border color change"
    },
    "touchTarget": { "minimum": "44px" },
    "motionPreference": "Respect prefers-reduced-motion; disable caustic shimmer entirely",
    "numericInputs": "Use inputmode=decimal and tabular numerals"
  },

  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },

  "tkinter": {
    "note": "Loads via StyleLoader in GUI_MULTI_STYLE_RETROFIT_GUIDE.md. Use Consolas for numeric result labels.",
    "root_bg": "#F0F9FF",
    "header_bg": "#075985",
    "header_fg": "#FFFFFF",
    "label_fg": "#082F49",
    "title_fg": "#0284C7",
    "unit_fg": "#475569",
    "entry_bg": "#FFFFFF",
    "entry_border": "#BAE6FD",
    "entry_focus": "#0284C7",
    "button_bg": "#0284C7",
    "button_fg": "#FFFFFF",
    "button_active": "#06B6D4",
    "result_font": ["Consolas", 20, "bold"],
    "status_flood": { "fg": "#DC2626", "bg": "#FEF2F2" },
    "status_action": { "fg": "#D97706", "bg": "#FFFBEB" },
    "status_normal": { "fg": "#059669", "bg": "#ECFDF5" }
  }
}
