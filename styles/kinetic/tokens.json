{
  "name": "Kinetic Typography",
  "version": "1.0.0",
  "created": "2025-12-03",
  "description": "High-energy brutalism meets kinetic poster design. Typography as the entire visual structure with constant motion, aggressive scale, and hard color inversions.",
  
  "colors": {
    "background": "#09090B",
    "foreground": "#FAFAFA",
    "muted": "#27272A",
    "mutedForeground": "#A1A1AA",
    "accent": "#DFE104",
    "accentForeground": "#000000",
    "border": "#3F3F46"
  },

  "typography": {
    "fontFamily": {
      "primary": "Space Grotesk",
      "fallback": "Inter, system-ui, sans-serif",
      "googleImport": "https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@300;400;500;600;700&display=swap"
    },
    "fontWeight": {
      "light": 300,
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "fontSize": {
      "hero": "clamp(3rem, 12vw, 14rem)",
      "sectionHeading": "clamp(2.5rem, 8vw, 6rem)",
      "cardTitle": {
        "mobile": "1.5rem",
        "tablet": "1.875rem",
        "desktop": "3.75rem"
      },
      "body": {
        "mobile": "1.125rem",
        "tablet": "1.25rem",
        "desktop": "1.5rem"
      },
      "small": {
        "mobile": "0.75rem",
        "tablet": "0.875rem",
        "desktop": "1.125rem"
      },
      "massiveNumber": {
        "mobile": "6rem",
        "desktop": "12rem"
      },
      "navigation": {
        "mobile": "0.875rem",
        "desktop": "1rem"
      }
    },
    "lineHeight": {
      "display": 0.8,
      "none": 1,
      "tight": 1.25,
      "normal": 1.5,
      "relaxed": 1.625
    },
    "letterSpacing": {
      "tighter": "-0.05em",
      "tight": "-0.025em",
      "normal": "0em",
      "wide": "0.025em",
      "widest": "0.1em"
    }
  },

  "spacing": {
    "base": 4,
    "scale": [0, 4, 8, 12, 16, 24, 32, 48, 64, 96, 128],
    "section": {
      "mobile": { "paddingY": 80, "paddingX": 16 },
      "tablet": { "paddingY": 96, "paddingX": 24 },
      "desktop": { "paddingY": 128, "paddingX": 32 }
    },
    "card": {
      "padding": 32,
      "paddingLarge": 48
    },
    "gap": {
      "tight": 16,
      "standard": 32,
      "wide": 48,
      "hairline": 1
    }
  },

  "borders": {
    "width": {
      "default": "1px",
      "medium": "2px",
      "heavy": "4px"
    },
    "color": "#3F3F46",
    "radius": {
      "none": "0px",
      "sm": "2px"
    }
  },

  "shadows": {
    "note": "This style uses NO shadows - completely flat design"
  },

  "animation": {
    "duration": {
      "fast": "200ms",
      "normal": "300ms",
      "slow": "500ms"
    },
    "easing": {
      "default": "ease-in-out",
      "linear": "linear"
    },
    "transforms": {
      "buttonHover": "scale(1.05)",
      "buttonActive": "scale(0.95)",
      "cardLift": "translateY(-4px)",
      "textSlide": "translateX(2rem)"
    },
    "marquee": {
      "speedFast": 80,
      "speedMedium": 40,
      "gradient": false,
      "autoFill": true
    }
  },

  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },

  "layout": {
    "maxWidth": {
      "hero": "95vw",
      "content": "90vw",
      "text": "672px"
    },
    "containerPadding": {
      "mobile": "1rem",
      "tablet": "1.5rem",
      "desktop": "2rem"
    }
  },

  "components": {
    "button": {
      "primary": {
        "background": "#DFE104",
        "text": "#000000",
        "border": "none",
        "height": {
          "small": "40px",
          "default": "56px",
          "large": "80px"
        }
      },
      "outline": {
        "background": "transparent",
        "text": "#FAFAFA",
        "border": "2px solid #3F3F46",
        "hoverBackground": "#FAFAFA",
        "hoverText": "#000000"
      },
      "ghost": {
        "background": "transparent",
        "text": "#FAFAFA",
        "border": "none",
        "hoverText": "#DFE104"
      }
    },
    "card": {
      "background": "#09090B",
      "border": "2px solid #3F3F46",
      "padding": "32px",
      "hover": {
        "background": "#DFE104",
        "border": "2px solid #DFE104",
        "text": "#000000"
      }
    },
    "input": {
      "height": "96px",
      "background": "transparent",
      "border": "none",
      "borderBottom": "2px solid #3F3F46",
      "focusBorderColor": "#DFE104",
      "fontSize": "2.25rem"
    }
  },

  "texture": {
    "noise": {
      "type": "svg",
      "filter": "feTurbulence",
      "baseFrequency": 0.8,
      "numOctaves": 4,
      "opacity": 0.03,
      "blendMode": "overlay",
      "position": "fixed"
    }
  },

  "accessibility": {
    "contrast": {
      "foregroundOnBackground": "15:1",
      "accentOnBackground": "12:1",
      "mutedOnBackground": "6:1"
    },
    "motionPreference": "respect prefers-reduced-motion",
    "minTouchTarget": "44px",
    "focusIndicator": "2px accent ring"
  },

  "dependencies": {
    "required": [
      "react-fast-marquee",
      "framer-motion"
    ],
    "optional": [
      "@radix-ui/react-accordion"
    ]
  }
}
