{
  "name": "Twisty",
  "version": "1.0.0",
  "created": "2025-12-29",
  "description": "Modern dark-mode Finance SaaS aesthetic inspired by Halo Lab's Twisty design. Features deep void backgrounds, violet-to-indigo gradients, layered surfaces, and clean data visualization with semantic color coding.",
  "mode": "dark",
  "keywords": ["fintech", "saas", "dashboard", "modern", "gradient", "professional", "dark-mode", "data-visualization", "clean"],
  "source": "Inspired by Halo Lab Dribbble: Dashboard for a Finance SaaS - Twisty",
  
  "colors": {
    "background": {
      "hex": "#0D0D12",
      "name": "Void Black",
      "usage": "Page background - deep dark base"
    },
    "backgroundSecondary": {
      "hex": "#13131A",
      "name": "Dark Navy",
      "usage": "Secondary backgrounds, nested containers"
    },
    "surface": {
      "hex": "#1A1A24",
      "name": "Card Surface",
      "usage": "Cards, panels, elevated elements"
    },
    "surfaceHover": {
      "hex": "#22222E",
      "name": "Surface Hover",
      "usage": "Interactive surface hover states"
    },
    "foreground": {
      "hex": "#FFFFFF",
      "name": "White",
      "usage": "Primary text, headings"
    },
    "textSecondary": {
      "hex": "#A0A0B0",
      "name": "Silver",
      "usage": "Secondary text, descriptions"
    },
    "textMuted": {
      "hex": "#6B6B7B",
      "name": "Muted Gray",
      "usage": "Tertiary text, hints, timestamps"
    },
    "primary": {
      "hex": "#8B5CF6",
      "name": "Violet 500",
      "usage": "Primary brand color, active states, CTAs"
    },
    "primaryLight": {
      "hex": "#A78BFA",
      "name": "Violet 400",
      "usage": "Lighter primary, hover states"
    },
    "secondary": {
      "hex": "#6366F1",
      "name": "Indigo 500",
      "usage": "Gradient end, secondary accents"
    },
    "accent": {
      "hex": "#22C55E",
      "name": "Emerald 500",
      "usage": "Success, positive values, growth indicators"
    },
    "accentRed": {
      "hex": "#EF4444",
      "name": "Red 500",
      "usage": "Error, negative values, decline indicators"
    },
    "accentYellow": {
      "hex": "#F59E0B",
      "name": "Amber 500",
      "usage": "Warning, pending states, caution"
    },
    "border": {
      "hex": "#2A2A38",
      "name": "Border Dark",
      "usage": "Card borders, dividers"
    },
    "borderLight": {
      "hex": "#1F1F2C",
      "name": "Border Subtle",
      "usage": "Subtle separators, inner borders"
    }
  },

  "gradients": {
    "primary": {
      "value": "linear-gradient(135deg, #8B5CF6 0%, #6366F1 100%)",
      "tailwind": "bg-gradient-to-br from-violet-500 to-indigo-500",
      "usage": "Primary buttons, hero cards, active navigation"
    },
    "primarySubtle": {
      "value": "linear-gradient(135deg, rgba(139, 92, 246, 0.15) 0%, rgba(99, 102, 241, 0.15) 100%)",
      "tailwind": "bg-gradient-to-br from-violet-500/15 to-indigo-500/15",
      "usage": "Icon backgrounds, subtle highlights"
    },
    "glow": {
      "value": "radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%)",
      "usage": "Decorative orbs on gradient cards"
    },
    "positiveSubtle": {
      "value": "rgba(34, 197, 94, 0.1)",
      "usage": "Positive change badge backgrounds"
    },
    "negativeSubtle": {
      "value": "rgba(239, 68, 68, 0.1)",
      "usage": "Negative change badge backgrounds"
    }
  },

  "typography": {
    "fontFamily": {
      "primary": "'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif",
      "googleImport": "https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
    },
    "scale": "Major Third (1.250)",
    "weights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700
    },
    "sizes": {
      "xs": { "size": "11px", "lineHeight": 1.4 },
      "sm": { "size": "12px", "lineHeight": 1.5 },
      "base": { "size": "14px", "lineHeight": 1.6 },
      "lg": { "size": "16px", "lineHeight": 1.5 },
      "xl": { "size": "20px", "lineHeight": 1.4 },
      "2xl": { "size": "28px", "lineHeight": 1.3, "letterSpacing": "-0.02em" },
      "3xl": { "size": "36px", "lineHeight": 1.2, "letterSpacing": "-0.02em" }
    },
    "elements": {
      "statValue": { "size": "28px", "weight": 700, "letterSpacing": "-0.02em" },
      "cardTitle": { "size": "16px", "weight": 600 },
      "label": { "size": "13px", "weight": 500, "color": "textMuted" },
      "body": { "size": "14px", "weight": 400 },
      "small": { "size": "12px", "weight": 500 }
    }
  },

  "spacing": {
    "containerMaxWidth": "1400px",
    "containerPadding": "24px",
    "cardPadding": "20px",
    "cardPaddingLarge": "24px",
    "gap": {
      "xs": "4px",
      "sm": "8px",
      "md": "12px",
      "lg": "16px",
      "xl": "24px",
      "2xl": "32px"
    }
  },

  "borders": {
    "width": {
      "default": "1px"
    },
    "radius": {
      "sm": "6px",
      "md": "8px",
      "lg": "10px",
      "xl": "12px",
      "2xl": "16px",
      "3xl": "20px",
      "full": "9999px"
    },
    "radiusUsage": {
      "badges": "sm (6px)",
      "periodTabs": "md (8px)",
      "inputs": "lg (10px)",
      "avatars": "lg (10px)",
      "cards": "xl (16px)",
      "balanceCard": "3xl (20px)",
      "transactionItems": "xl (12px)"
    }
  },

  "shadows": {
    "none": {
      "value": "none",
      "usage": "Default - Twisty uses minimal shadows, relies on border/surface contrast"
    },
    "subtle": {
      "value": "0 1px 2px 0 rgba(0, 0, 0, 0.3)",
      "usage": "Subtle depth for dropdowns"
    },
    "elevated": {
      "value": "0 4px 12px rgba(0, 0, 0, 0.4)",
      "usage": "Modal/overlay elevation"
    }
  },

  "effects": {
    "blur": {
      "backdrop": "blur(10px)",
      "usage": "Frosted glass effect on balance card buttons"
    },
    "opacity": {
      "disabledElement": "0.5",
      "hoverOverlay": "0.1"
    },
    "transitions": {
      "default": "all 0.2s ease",
      "fast": "all 0.15s ease",
      "slow": "all 0.3s ease"
    }
  },

  "animation": {
    "duration": {
      "fast": "150ms",
      "default": "200ms",
      "slow": "300ms"
    },
    "easing": {
      "default": "ease",
      "smooth": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "hoverEffects": {
      "cardHover": { "background": "surfaceHover" },
      "buttonHover": { "opacity": "0.9" },
      "navActiveSlide": { "background": "gradient" }
    }
  },

  "components": {
    "nav": {
      "container": {
        "background": "#1A1A24",
        "border": "1px solid #2A2A38",
        "borderRadius": "12px",
        "padding": "4px"
      },
      "item": {
        "padding": "10px 20px",
        "borderRadius": "8px",
        "fontSize": "14px",
        "fontWeight": 500
      },
      "itemActive": {
        "background": "gradient-primary",
        "color": "#FFFFFF"
      },
      "itemInactive": {
        "background": "transparent",
        "color": "#A0A0B0"
      }
    },
    "statCard": {
      "background": "#1A1A24",
      "border": "1px solid #2A2A38",
      "borderRadius": "16px",
      "padding": "20px"
    },
    "changeBadge": {
      "positive": {
        "background": "rgba(34, 197, 94, 0.1)",
        "color": "#22C55E",
        "padding": "4px 8px",
        "borderRadius": "6px",
        "fontSize": "12px",
        "fontWeight": 500
      },
      "negative": {
        "background": "rgba(239, 68, 68, 0.1)",
        "color": "#EF4444",
        "padding": "4px 8px",
        "borderRadius": "6px",
        "fontSize": "12px",
        "fontWeight": 500
      }
    },
    "balanceCard": {
      "background": "gradient-primary",
      "borderRadius": "20px",
      "padding": "28px",
      "hasGlowOrb": true
    },
    "button": {
      "primary": {
        "background": "gradient-primary",
        "text": "#FFFFFF",
        "fontWeight": 500,
        "padding": "12px 24px",
        "borderRadius": "10px"
      },
      "ghost": {
        "background": "rgba(255,255,255,0.2)",
        "text": "#FFFFFF",
        "fontWeight": 500,
        "backdropFilter": "blur(10px)"
      },
      "outline": {
        "background": "transparent",
        "border": "1px solid rgba(255,255,255,0.3)",
        "text": "#FFFFFF"
      }
    },
    "input": {
      "background": "#1A1A24",
      "text": "#FFFFFF",
      "placeholder": "#6B6B7B",
      "border": "1px solid #2A2A38",
      "borderRadius": "10px",
      "padding": "10px 16px",
      "focusBorder": "#8B5CF6"
    },
    "transactionItem": {
      "background": "#13131A",
      "borderRadius": "12px",
      "padding": "14px",
      "iconSize": "44px",
      "iconRadius": "10px"
    },
    "periodSelector": {
      "container": {
        "background": "#13131A",
        "padding": "4px",
        "borderRadius": "8px"
      },
      "tab": {
        "padding": "6px 12px",
        "borderRadius": "6px",
        "fontSize": "12px",
        "fontWeight": 500
      },
      "tabActive": {
        "background": "#8B5CF6",
        "color": "#FFFFFF"
      },
      "tabInactive": {
        "background": "transparent",
        "color": "#6B6B7B"
      }
    },
    "chart": {
      "barDefault": "#2A2A38",
      "barActive": "gradient-primary",
      "barRadius": "6px 6px 0 0",
      "labelColor": "#6B6B7B"
    },
    "avatar": {
      "size": "40px",
      "borderRadius": "10px",
      "background": "gradient-primary",
      "text": "#FFFFFF",
      "fontWeight": 600
    }
  },

  "semanticColors": {
    "positive": {
      "text": "#22C55E",
      "background": "rgba(34, 197, 94, 0.1)",
      "icon": "↑"
    },
    "negative": {
      "text": "#EF4444",
      "background": "rgba(239, 68, 68, 0.1)",
      "icon": "↓"
    },
    "warning": {
      "text": "#F59E0B",
      "background": "rgba(245, 158, 11, 0.1)"
    },
    "info": {
      "text": "#6366F1",
      "background": "rgba(99, 102, 241, 0.15)"
    }
  },

  "accessibility": {
    "contrastRatios": {
      "textOnBackground": "18.1:1 (White on #0D0D12)",
      "textOnSurface": "15.3:1 (White on #1A1A24)",
      "textOnPrimary": "6.8:1 (White on #8B5CF6)"
    },
    "focusRing": {
      "width": "2px",
      "color": "#8B5CF6",
      "offset": "2px",
      "style": "solid"
    },
    "touchTarget": {
      "minimum": "44px"
    }
  },

  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  },

  "layout": {
    "dashboard": {
      "mainGrid": "1fr 360px",
      "gap": "24px"
    },
    "statsGrid": "repeat(4, 1fr)",
    "actionsGrid": "repeat(3, 1fr)"
  }
}
