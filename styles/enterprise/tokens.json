{
  "name": "Enterprise",
  "version": "1.0.0",
  "created": "2025-12-03",
  "description": "Modern enterprise SaaS aesthetic - professional yet approachable, sophisticated yet friendly. Features indigo-violet gradients, colored shadows, isometric depth, and elevated cards.",
  "mode": "light",
  "keywords": ["trustworthy", "vibrant", "polished", "dimensional", "modern", "approachable", "enterprise-ready", "elegant"],
  
  "colors": {
    "background": {
      "hex": "#F8FAFC",
      "name": "Slate 50",
      "usage": "Page background - subtle cool grey/white base"
    },
    "foreground": {
      "hex": "#0F172A",
      "name": "Slate 900",
      "usage": "Primary text - high contrast, sharp"
    },
    "surface": {
      "hex": "#FFFFFF",
      "name": "White",
      "usage": "Cards and raised elements"
    },
    "primary": {
      "hex": "#4F46E5",
      "name": "Indigo 600",
      "usage": "Core brand color - buttons, links, active states"
    },
    "secondary": {
      "hex": "#7C3AED",
      "name": "Violet 600",
      "usage": "Gradients and secondary accents"
    },
    "muted": {
      "hex": "#64748B",
      "name": "Slate 500",
      "usage": "Supporting/secondary text"
    },
    "accent": {
      "hex": "#10B981",
      "name": "Emerald 500",
      "usage": "Success indicators, positive states"
    },
    "border": {
      "hex": "#E2E8F0",
      "name": "Slate 200",
      "usage": "Default borders, subtle separation"
    },
    "borderLight": {
      "hex": "#F1F5F9",
      "name": "Slate 100",
      "usage": "Card borders, lighter separation"
    },
    "primaryLight": {
      "hex": "#EEF2FF",
      "name": "Indigo 50",
      "usage": "Icon badge backgrounds, subtle highlights"
    },
    "primaryMedium": {
      "hex": "#C7D2FE",
      "name": "Indigo 200",
      "usage": "Background blobs, decorative elements"
    },
    "secondaryLight": {
      "hex": "#DDD6FE",
      "name": "Violet 200",
      "usage": "Background blobs, decorative gradients"
    },
    "dark": {
      "hex": "#312E81",
      "name": "Indigo 900",
      "usage": "Dark CTA backgrounds"
    },
    "darker": {
      "hex": "#1E1B4B",
      "name": "Indigo 950",
      "usage": "Gradient end for dark sections"
    }
  },

  "gradients": {
    "primary": {
      "value": "linear-gradient(to right, #4F46E5, #7C3AED)",
      "tailwind": "bg-gradient-to-r from-indigo-600 to-violet-600",
      "usage": "Primary buttons, active states"
    },
    "text": {
      "value": "linear-gradient(to right, #4F46E5, #7C3AED)",
      "tailwind": "bg-gradient-to-r from-indigo-600 to-violet-600 bg-clip-text text-transparent",
      "usage": "Gradient text for headline emphasis"
    },
    "backgroundSubtle": {
      "value": "linear-gradient(to right, #C7D2FE, #DDD6FE)",
      "tailwind": "bg-gradient-to-r from-indigo-200 to-violet-200",
      "usage": "Container backgrounds, decorative blobs"
    },
    "backgroundBlob": {
      "value": "linear-gradient(to bottom-right, #C7D2FE, #DDD6FE)",
      "tailwind": "bg-gradient-to-br from-indigo-200 to-violet-200",
      "usage": "Atmospheric background orbs"
    },
    "darkCTA": {
      "value": "linear-gradient(to bottom, #312E81, #1E1B4B)",
      "tailwind": "bg-gradient-to-b from-indigo-900 to-indigo-950",
      "usage": "Dramatic dark section backgrounds"
    }
  },

  "typography": {
    "fontFamily": {
      "primary": "'Plus Jakarta Sans', system-ui, sans-serif",
      "googleImport": "https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;500;600;700;800&display=swap"
    },
    "scale": "Major Third (1.250)",
    "weights": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800
    },
    "sizes": {
      "xs": { "size": "12px", "lineHeight": 1.4, "letterSpacing": "0.01em" },
      "sm": { "size": "14px", "lineHeight": 1.5, "letterSpacing": "0" },
      "base": { "size": "16px", "lineHeight": 1.65, "letterSpacing": "0" },
      "lg": { "size": "18px", "lineHeight": 1.5, "letterSpacing": "0" },
      "xl": { "size": "20px", "lineHeight": 1.3, "letterSpacing": "0" },
      "2xl": { "size": "24px", "lineHeight": 1.25, "letterSpacing": "-0.01em" },
      "3xl": { "size": "30px", "lineHeight": 1.2, "letterSpacing": "-0.01em" },
      "4xl": { "size": "36px", "lineHeight": 1.15, "letterSpacing": "-0.02em" },
      "5xl": { "size": "48px", "lineHeight": 1.1, "letterSpacing": "-0.02em" },
      "6xl": { "size": "60px", "lineHeight": 1.1, "letterSpacing": "-0.02em" }
    },
    "elements": {
      "heroDesktop": { "size": "6xl", "weight": 800, "lineHeight": 1.1, "letterSpacing": "-0.02em" },
      "heroMobile": { "size": "4xl", "weight": 800, "lineHeight": 1.1, "letterSpacing": "-0.02em" },
      "sectionHeading": { "size": "4xl", "weight": 700, "lineHeight": 1.2, "letterSpacing": "-0.01em" },
      "cardTitle": { "size": "xl", "weight": 600, "lineHeight": 1.3, "letterSpacing": "0" },
      "body": { "size": "base", "weight": 400, "lineHeight": 1.65, "letterSpacing": "0" },
      "navLabel": { "size": "sm", "weight": 500, "lineHeight": 1.5, "letterSpacing": "0" },
      "inputLabel": { "size": "sm", "weight": 600, "lineHeight": 1.5, "letterSpacing": "0" }
    }
  },

  "spacing": {
    "containerMaxWidth": "1280px",
    "containerPadding": {
      "mobile": "16px",
      "tablet": "24px",
      "desktop": "32px"
    },
    "sectionPadding": {
      "mobile": "64px",
      "tablet": "80px",
      "desktop": "96px"
    },
    "cardPadding": "24px",
    "inputPadding": {
      "x": "16px",
      "y": "10px"
    },
    "buttonPadding": {
      "x": "24px",
      "y": "12px"
    },
    "gap": {
      "xs": "8px",
      "sm": "12px",
      "md": "16px",
      "lg": "24px",
      "xl": "32px",
      "2xl": "48px"
    }
  },

  "borders": {
    "width": {
      "default": "1px",
      "focus": "2px"
    },
    "radius": {
      "sm": "6px",
      "md": "8px",
      "lg": "8px",
      "xl": "12px",
      "2xl": "16px",
      "full": "9999px"
    },
    "radiusUsage": {
      "cards": "xl (12px)",
      "inputs": "lg (8px)",
      "buttonsPrimary": "full (pill)",
      "buttonsSecondary": "lg (8px)",
      "iconContainers": "xl (12px)",
      "avatars": "full"
    }
  },

  "shadows": {
    "card": {
      "value": "0 4px 20px -2px rgba(79, 70, 229, 0.1)",
      "usage": "Default card elevation - soft blue-tinted"
    },
    "cardHover": {
      "value": "0 10px 25px -5px rgba(79, 70, 229, 0.15), 0 8px 10px -6px rgba(79, 70, 229, 0.1)",
      "usage": "Multi-layer depth on hover interaction"
    },
    "button": {
      "value": "0 4px 14px 0 rgba(79, 70, 229, 0.3)",
      "usage": "Strong presence for primary CTAs"
    },
    "buttonHover": {
      "value": "0 6px 20px 0 rgba(79, 70, 229, 0.4)",
      "usage": "Enhanced button shadow on hover"
    },
    "glow": {
      "value": "0 0 20px rgba(79, 70, 229, 0.5)",
      "usage": "Ethereal glow for numbered badges"
    },
    "input": {
      "value": "0 1px 2px 0 rgba(0, 0, 0, 0.05)",
      "usage": "Subtle input field shadow"
    }
  },

  "effects": {
    "blur": {
      "blob": "blur-3xl",
      "value": "64px"
    },
    "opacity": {
      "blobStrong": "0.3",
      "blobSubtle": "0.2"
    },
    "transforms": {
      "isometric": {
        "perspective": "2000px",
        "rotateX": "5deg",
        "rotateY": "-12deg"
      },
      "isometricHover": {
        "rotateX": "2deg",
        "rotateY": "-8deg"
      },
      "cardHoverLift": "-4px",
      "buttonHoverLift": "-2px"
    }
  },

  "animation": {
    "duration": {
      "fast": "150ms",
      "default": "200ms",
      "slow": "300ms",
      "verySlow": "500ms",
      "float": "4000ms"
    },
    "easing": {
      "default": "ease-out",
      "smooth": "cubic-bezier(0.4, 0, 0.2, 1)"
    },
    "keyframes": {
      "float": {
        "0%, 100%": { "transform": "translateY(0px)" },
        "50%": { "transform": "translateY(-10px)" }
      },
      "pulse": {
        "0%, 100%": { "opacity": "1" },
        "50%": { "opacity": "0.5" }
      }
    },
    "hoverEffects": {
      "cardLift": { "transform": "translateY(-4px)", "shadow": "cardHover" },
      "buttonLift": { "transform": "translateY(-2px)", "shadow": "buttonHover" },
      "arrowSlide": { "transform": "translateX(4px)" },
      "imageZoom": { "transform": "scale(1.05)" },
      "accordionRotate": { "transform": "rotate(180deg)" }
    }
  },

  "components": {
    "button": {
      "primary": {
        "background": "gradient-primary",
        "text": "#FFFFFF",
        "fontWeight": 500,
        "padding": "12px 24px",
        "radius": "full",
        "shadow": "button",
        "hoverTransform": "translateY(-2px)",
        "hoverShadow": "buttonHover"
      },
      "secondary": {
        "background": "#FFFFFF",
        "text": "#334155",
        "fontWeight": 500,
        "padding": "12px 24px",
        "radius": "lg",
        "border": "1px solid #E2E8F0",
        "hoverBackground": "#F8FAFC",
        "hoverBorder": "1px solid #CBD5E1"
      }
    },
    "card": {
      "background": "#FFFFFF",
      "radius": "xl",
      "border": "1px solid #F1F5F9",
      "shadow": "card",
      "padding": "24px",
      "hoverTransform": "translateY(-4px)",
      "hoverShadow": "cardHover"
    },
    "input": {
      "background": "#FFFFFF",
      "text": "#0F172A",
      "placeholder": "#94A3B8",
      "border": "1px solid #E2E8F0",
      "radius": "lg",
      "padding": "10px 16px",
      "focusRing": "2px solid #4F46E5",
      "focusRingOffset": "1px",
      "focusBorder": "#4F46E5"
    },
    "iconBadge": {
      "small": {
        "size": "48px",
        "radius": "xl",
        "background": "#EEF2FF",
        "iconColor": "#4F46E5",
        "iconSize": "24px"
      },
      "large": {
        "size": "56px",
        "radius": "xl",
        "background": "#EEF2FF",
        "iconColor": "#4F46E5",
        "iconSize": "28px"
      }
    }
  },

  "accessibility": {
    "contrastRatios": {
      "textOnBackground": "17.4:1 (Slate 900 on Slate 50)",
      "textOnPrimary": "8.6:1 (White on Indigo 600)",
      "textOnDark": "15.2:1 (White on Indigo 900)"
    },
    "focusRing": {
      "width": "2px",
      "color": "#4F46E5",
      "offset": "2px",
      "style": "solid"
    },
    "touchTarget": {
      "minimum": "44px"
    },
    "motionPreference": "Respect prefers-reduced-motion"
  },

  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px",
    "2xl": "1536px"
  }
}
