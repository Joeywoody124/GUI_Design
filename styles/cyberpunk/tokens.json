{
  "name": "Cyberpunk / Glitch",
  "version": "1.0.0",
  "created": "2025-12-03",
  "description": "High-Tech, Low-Life. Digital dystopia with neon-drenched aesthetics, glitch effects, and terminal-inspired UI. Draws from Blade Runner, Akira, The Matrix, and Ghost in the Shell.",

  "colors": {
    "background": "#0a0a0f",
    "foreground": "#e0e0e0",
    "card": "#12121a",
    "muted": "#1c1c2e",
    "mutedForeground": "#6b7280",
    "accent": "#00ff88",
    "accentSecondary": "#ff00ff",
    "accentTertiary": "#00d4ff",
    "border": "#2a2a3a",
    "input": "#12121a",
    "ring": "#00ff88",
    "destructive": "#ff3366"
  },

  "colorNames": {
    "background": "Void Black",
    "card": "Deep Purple-Black",
    "muted": "Elevated Chrome",
    "accent": "Matrix Green / Electric Green",
    "accentSecondary": "Hot Magenta",
    "accentTertiary": "Electric Cyan",
    "destructive": "Danger Pink"
  },

  "typography": {
    "fontFamily": {
      "heading": "Orbitron",
      "body": "JetBrains Mono",
      "accent": "Share Tech Mono",
      "fallback": "monospace",
      "googleImport": "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700&family=Orbitron:wght@400;500;600;700;800;900&family=Share+Tech+Mono&display=swap"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "semibold": 600,
      "bold": 700,
      "extrabold": 800,
      "black": 900
    },
    "fontSize": {
      "hero": {
        "mobile": "3rem",
        "tablet": "4.5rem",
        "desktop": "6rem"
      },
      "sectionHeading": {
        "mobile": "2.25rem",
        "desktop": "3rem"
      },
      "subsectionHeading": {
        "mobile": "1.25rem",
        "desktop": "1.5rem"
      },
      "body": "1rem",
      "label": "0.875rem"
    },
    "lineHeight": {
      "tight": 1.1,
      "normal": 1.5,
      "relaxed": 1.625
    },
    "letterSpacing": {
      "tight": "-0.025em",
      "normal": "0em",
      "wide": "0.025em",
      "wider": "0.05em",
      "widest": "0.1em",
      "ultra": "0.2em"
    },
    "textTransform": {
      "headings": "uppercase",
      "labels": "uppercase",
      "body": "none"
    }
  },

  "spacing": {
    "base": 8,
    "scale": [0, 4, 8, 12, 16, 24, 32, 48, 64, 96, 128],
    "section": {
      "mobile": { "paddingY": 64, "paddingX": 16 },
      "tablet": { "paddingY": 80, "paddingX": 24 },
      "desktop": { "paddingY": 96, "paddingX": 32 }
    },
    "card": {
      "padding": 24,
      "paddingLarge": 32
    }
  },

  "borders": {
    "width": {
      "default": "1px",
      "emphasis": "2px"
    },
    "color": {
      "default": "#2a2a3a",
      "accent": "#00ff88",
      "secondary": "#ff00ff",
      "tertiary": "#00d4ff"
    },
    "radius": {
      "none": "0px",
      "sm": "2px",
      "base": "4px"
    }
  },

  "clipPaths": {
    "chamfer": "polygon(0 10px, 10px 0, calc(100% - 10px) 0, 100% 10px, 100% calc(100% - 10px), calc(100% - 10px) 100%, 10px 100%, 0 calc(100% - 10px))",
    "chamferSm": "polygon(0 4px, 4px 0, calc(100% - 4px) 0, 100% 4px, 100% calc(100% - 4px), calc(100% - 4px) 100%, 4px 100%, 0 calc(100% - 4px))",
    "chamferLg": "polygon(0 16px, 16px 0, calc(100% - 16px) 0, 100% 16px, 100% calc(100% - 16px), calc(100% - 16px) 100%, 16px 100%, 0 calc(100% - 16px))"
  },

  "shadows": {
    "neon": "0 0 5px #00ff88, 0 0 10px #00ff8840",
    "neonSm": "0 0 3px #00ff88, 0 0 6px #00ff8830",
    "neonLg": "0 0 10px #00ff88, 0 0 20px #00ff8860, 0 0 40px #00ff8830",
    "neonSecondary": "0 0 5px #ff00ff, 0 0 20px #ff00ff60",
    "neonTertiary": "0 0 5px #00d4ff, 0 0 20px #00d4ff60"
  },

  "effects": {
    "chromaticAberration": "-2px 0 #ff00ff, 2px 0 #00d4ff",
    "textGlow": "0 0 10px rgba(0, 255, 136, 0.5)",
    "scanlines": "repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0, 0, 0, 0.3) 2px, rgba(0, 0, 0, 0.3) 4px)",
    "circuitGrid": "linear-gradient(rgba(0, 255, 136, 0.03) 1px, transparent 1px), linear-gradient(90deg, rgba(0, 255, 136, 0.03) 1px, transparent 1px)"
  },

  "animation": {
    "duration": {
      "fast": "100ms",
      "base": "150ms",
      "slow": "300ms"
    },
    "easing": {
      "default": "cubic-bezier(0.4, 0, 0.2, 1)",
      "digital": "steps(4)"
    },
    "keyframes": {
      "blink": {
        "50%": { "opacity": 0 }
      },
      "glitch": {
        "0%, 100%": { "transform": "translate(0)" },
        "20%": { "transform": "translate(-2px, 2px)" },
        "40%": { "transform": "translate(2px, -2px)" },
        "60%": { "transform": "translate(-1px, -1px)" },
        "80%": { "transform": "translate(1px, 1px)" }
      },
      "rgbShift": {
        "0%, 100%": { "textShadow": "-2px 0 #ff00ff, 2px 0 #00d4ff" },
        "50%": { "textShadow": "2px 0 #ff00ff, -2px 0 #00d4ff" }
      }
    }
  },

  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },

  "layout": {
    "maxWidth": {
      "content": "1280px",
      "narrow": "896px"
    }
  },

  "components": {
    "button": {
      "default": {
        "background": "transparent",
        "text": "#00ff88",
        "border": "2px solid #00ff88",
        "hoverBackground": "#00ff88",
        "hoverText": "#0a0a0f",
        "height": {
          "small": "40px",
          "default": "48px",
          "large": "56px"
        }
      },
      "secondary": {
        "background": "transparent",
        "text": "#ff00ff",
        "border": "2px solid #ff00ff",
        "hoverBackground": "#ff00ff",
        "hoverText": "#0a0a0f"
      },
      "glitch": {
        "background": "#00ff88",
        "text": "#0a0a0f",
        "border": "none",
        "hoverBrightness": 1.1
      }
    },
    "card": {
      "default": {
        "background": "#12121a",
        "border": "1px solid #2a2a3a",
        "hoverBorder": "#00ff88"
      },
      "terminal": {
        "background": "#0a0a0f",
        "border": "1px solid #2a2a3a",
        "headerDots": ["#ff3366", "#ffcc00", "#00ff88"]
      },
      "holographic": {
        "background": "rgba(28, 28, 46, 0.3)",
        "border": "1px solid rgba(0, 255, 136, 0.3)",
        "backdropBlur": "8px"
      }
    },
    "input": {
      "background": "#12121a",
      "border": "1px solid #2a2a3a",
      "focusBorder": "#00ff88",
      "text": "#00ff88",
      "placeholder": "#6b7280",
      "prefix": ">"
    }
  },

  "accessibility": {
    "contrast": {
      "accentOnBackground": "7.5:1",
      "foregroundOnBackground": "13:1"
    },
    "focusRing": "2px solid #00ff88 with 2px offset",
    "minTouchTarget": "44px",
    "reducedMotion": "Disable glitch animations, keep static chromatic aberration"
  },

  "decorative": {
    "terminalPrefix": ">",
    "cursorSymbol": "█",
    "trafficLightDots": ["#ff3366", "#ffcc00", "#00ff88"]
  }
}
