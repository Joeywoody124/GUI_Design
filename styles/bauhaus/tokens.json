{
  "name": "Bauhaus",
  "version": "1.0.0",
  "created": "2025-12-03",
  "description": "Constructivist modernism inspired by 1920s Bauhaus movement. Form follows function with geometric purity.",
  
  "colors": {
    "background": "#F0F0F0",
    "foreground": "#121212",
    "primary": {
      "red": "#D02020",
      "blue": "#1040C0",
      "yellow": "#F0C020"
    },
    "border": "#121212",
    "muted": "#E0E0E0",
    "accent": {
      "yellowLight": "#FFF9C4"
    }
  },

  "typography": {
    "fontFamily": {
      "primary": "Outfit",
      "fallback": "system-ui, sans-serif",
      "googleImport": "https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;700;900&display=swap"
    },
    "fontWeight": {
      "regular": 400,
      "medium": 500,
      "bold": 700,
      "black": 900
    },
    "fontSize": {
      "display": {
        "mobile": "2.25rem",
        "tablet": "3.75rem",
        "desktop": "6rem"
      },
      "heading": {
        "mobile": "1.5rem",
        "tablet": "1.875rem",
        "desktop": "2.25rem"
      },
      "body": {
        "mobile": "1rem",
        "desktop": "1.125rem"
      },
      "small": "0.875rem"
    },
    "lineHeight": {
      "tight": 0.9,
      "normal": 1.5,
      "relaxed": 1.625
    },
    "letterSpacing": {
      "tighter": "-0.05em",
      "wider": "0.05em",
      "widest": "0.1em"
    }
  },

  "spacing": {
    "base": 4,
    "scale": [0, 4, 8, 12, 16, 24, 32, 48, 64, 96],
    "section": {
      "mobile": { "paddingY": 48, "paddingX": 16 },
      "tablet": { "paddingY": 64, "paddingX": 24 },
      "desktop": { "paddingY": 96, "paddingX": 32 }
    }
  },

  "borders": {
    "width": {
      "thin": "2px",
      "thick": "4px"
    },
    "color": "#121212",
    "radius": {
      "none": "0px",
      "full": "9999px"
    }
  },

  "shadows": {
    "small": "3px 3px 0px 0px #121212",
    "medium": "6px 6px 0px 0px #121212",
    "large": "8px 8px 0px 0px #121212",
    "none": "none"
  },

  "animation": {
    "duration": {
      "fast": "200ms",
      "normal": "300ms"
    },
    "easing": "ease-out",
    "transforms": {
      "buttonPress": "translate(2px, 2px)",
      "cardHover": "translateY(-4px)",
      "rotate45": "rotate(45deg)",
      "rotate180": "rotate(180deg)"
    }
  },

  "breakpoints": {
    "sm": "640px",
    "md": "768px",
    "lg": "1024px",
    "xl": "1280px"
  },

  "layout": {
    "maxWidth": "80rem",
    "containerPadding": {
      "mobile": "1rem",
      "tablet": "1.5rem",
      "desktop": "2rem"
    }
  },

  "components": {
    "button": {
      "primary": {
        "background": "#D02020",
        "text": "#FFFFFF",
        "border": "2px solid #121212",
        "shadow": "4px 4px 0px 0px #121212"
      },
      "secondary": {
        "background": "#1040C0",
        "text": "#FFFFFF",
        "border": "2px solid #121212",
        "shadow": "4px 4px 0px 0px #121212"
      },
      "yellow": {
        "background": "#F0C020",
        "text": "#121212",
        "border": "2px solid #121212",
        "shadow": "4px 4px 0px 0px #121212"
      },
      "outline": {
        "background": "#FFFFFF",
        "text": "#121212",
        "border": "2px solid #121212",
        "shadow": "4px 4px 0px 0px #121212"
      }
    },
    "card": {
      "background": "#FFFFFF",
      "border": "4px solid #121212",
      "shadow": "8px 8px 0px 0px #121212",
      "padding": "24px"
    },
    "accordion": {
      "closed": {
        "background": "#FFFFFF",
        "border": "4px solid #121212",
        "shadow": "4px 4px 0px 0px #121212"
      },
      "open": {
        "headerBackground": "#D02020",
        "headerText": "#FFFFFF",
        "contentBackground": "#FFF9C4",
        "contentText": "#121212"
      }
    }
  },

  "patterns": {
    "dotGrid": {
      "css": "radial-gradient(#fff 2px, transparent 2px)",
      "size": "20px 20px"
    }
  },

  "icons": {
    "library": "lucide-react",
    "strokeWidth": 2,
    "sizes": {
      "sm": "1.5rem",
      "md": "2rem",
      "lg": "2.5rem"
    }
  }
}
